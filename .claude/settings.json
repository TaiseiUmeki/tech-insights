{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(wget *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(./config/credentials.json)",
      "Bash(cat .env*)",
      "Bash(cat */.env*)",
      "Bash(cat **/*.pem)",
      "Bash(cat **/*.key)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-command.sh"
          }
        ]
      }
    ]
  }
}
