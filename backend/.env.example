# Application
ENVIRONMENT=development

# 認証機能の有効/無効（true: 有効, false: 無効）
# false にすると、認証なしでAPIにアクセス可能になります
ENABLE_AUTH=false

# Database
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_DB=ai_solution_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Database URL for SQLAlchemy
DATABASE_URL=postgresql+psycopg2://app_user:app_password@db:5432/ai_solution_db

# JWT Settings (RS256)
# RSA鍵ペアを生成: task generate-rsa-keys
#   生成された backend/.env.jwt-keys.local の中身を JWT_PRIVATE_KEY / JWT_PUBLIC_KEY に貼り付ける
#   （\n エスケープ変換は自動で行われます）
JWT_ALGORITHM=RS256
JWT_EXPIRATION_HOURS=24
JWT_PRIVATE_KEY=your-private-key-here
JWT_PUBLIC_KEY=your-public-key-here

# ============================================================
# オプションサービスの環境変数（docker-compose.yml で有効化したものだけ
# 合わせてコメントアウトを解除してください）
# ============================================================

# ---- AWS / Object Storage (S3) ----
# ローカルは MinIO に向け、本番では AWS_S3_ENDPOINT_URL を空にすると AWS S3 (本物) に接続される
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_S3_ENDPOINT_URL=http://minio:9000
# S3_BUCKET_NAME=ai-solution-bucket

# ---- AWS / Message Queue (SQS) ----
# ローカルは ElasticMQ に向け、本番では AWS_SQS_ENDPOINT_URL を空にすると AWS SQS (本物) に接続される
# AWS_SQS_ENDPOINT_URL=http://elasticmq:9324
# SQS_QUEUE_URL=http://elasticmq:9324/000000000000/default-queue

# ---- Redis ----
# REDIS_URL=redis://redis:6379/0
